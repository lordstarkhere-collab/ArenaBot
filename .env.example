# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id_here

# ── Groq AI ───────────────────────────────────────────────────────────────────
# All 3 keys are required. Get free keys at: https://console.groq.com
GROQ_API_KEY_1=gsk_...
GROQ_API_KEY_2=gsk_...
GROQ_API_KEY_3=gsk_...

# ── Database ──────────────────────────────────────────────────────────────────
# Railway: auto-provided when you add a PostgreSQL plugin.
# Local: postgresql://user:password@localhost:5432/arenabot
DATABASE_URL=postgresql://...

# ── Optional ──────────────────────────────────────────────────────────────────
# Only needed if you move the knowledge base files to a custom location.
# Defaults to: attached_assets/mech_data/knowledge  (relative to project root)
# KNOWLEDGE_DIR=/absolute/path/to/knowledge
